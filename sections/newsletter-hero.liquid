<section
  data-section-id="{{ section.id }}"
  data-section-type="newsletter-hero"
  class="
    newsletter-hero
    section
    {% if section.settings.section_contrast -%}
      section--contrast
    {%- endif %}"
  role="img"
>	<div class="section_inner">
    <div style="margin: 24px 0">
      {%- unless section.settings.title == blank -%}
        <h2 class="newsletter__heading ff-heading fs-heading-2-base fs-heading-2-large-ns">
          {{ section.settings.title | newline_to_br }}
        </h2>
      {%- endunless -%}

      {%- unless section.settings.subheading == blank -%}
        <div class="newsletter__subheading rte ff-body fs-body-small fs-body-base-ns">
          {{ section.settings.subheading }}
        </div>
      {%- endunless -%}
    </div>

    {% render 'newsletter-form' id: 'newsletter-dynamic' %}
  </div>
</section>

{% schema %}
  {
    "name": "t:sections.newsletter_hero.name",
    "tag": "section",
    "class": "shopify-section--stackable shopify-section--extra-small shopify-section--text-first",
    "settings": [
      {
        "id": "title",
        "type": "text",
        "label": "t:sections.newsletter.settings.title.label",
        "default": "Subscribe"
      },
      {
        "id": "subheading",
        "type": "richtext",
        "label": "t:sections.newsletter.settings.subheading.label",
        "default": "<p>Sign up for our newsletter</p>"
      },
      {
        "type": "paragraph",
      "content": "t:sections.newsletter.settings.paragraph.content"
      },
      {
        "id": "section_contrast",
        "type": "checkbox",
        "label": "t:sections.newsletter.settings.section_contrast.label",
        "default": true
      }
    ],
    "presets": [
      {
        "name": "t:sections.newsletter_hero.presets.name"
      }
    ]
  }
{% endschema %}